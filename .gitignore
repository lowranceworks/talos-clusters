# Ignore everything by default
*

# But track encrypted files
!*.enc.*

# Track SOPS configuration
!.sops.yaml

# Track directory structure (so Git doesn't lose empty dirs)
!*/

# Track common configuration files
!.gitignore
!Taskfile.yaml
!README.md

# Track Encrypted files
!*.enc
!*.enc.*

# Track docs directory and all its contents
!docs/
!docs/**.md

# If you want to track already-encrypted-in-place files (SOPS encrypts YAML in-place)
# Uncomment these lines:
# !*.yaml
# !.env
# !kubeconfig
# !talosconfig
